{
  "name": "orgos",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bash -lc 'npm run dev:redis-local & sleep 1; npm --workspace @orgos/api run dev & npm --workspace @orgos/web run dev'",
    "build": "turbo run build",
    "test": "npm run guard:schemas && npm --workspace @orgos/api run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "eval:agents": "node scripts/eval-agents.mjs",
    "guard:schemas": "node scripts/check-legacy-schema-refs.mjs",
    "smoke:local": "node scripts/smoke-local.js",
    "db:apply-remote": "bash scripts/apply-remote-schema.sh",
    "db:apply-remote-direct": "node scripts/apply-remote-schema-direct.mjs",
    "db:reset-nonprod": "node scripts/reset-nonprod-supabase.mjs",
    "dev:redis-local": "node scripts/start-local-redis.mjs"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "ioredis": "^5.3.2",
    "pg": "^8.11.0",
    "redis-memory-server": "^0.16.1",
    "turbo": "^2.0.12",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "dotenv": "^17.4.1"
  }
}
