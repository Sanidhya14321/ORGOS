{
  "name": "orgos",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --workspace @orgos/api run dev & npm --workspace @orgos/web run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "smoke:local": "node scripts/smoke-local.js",
    "db:apply-remote": "bash scripts/apply-remote-schema.sh",
    "e2e:auth-goals": "bash scripts/e2e-auth-goals.sh"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "turbo": "^2.0.12",
    "typescript": "^5.6.3",
    "pg": "^8.11.0",
    "ioredis": "^5.3.2"
  },
  "dependencies": {
    "dotenv": "^17.4.1"
  }
}
